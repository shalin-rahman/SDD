{
  "name": "emcap-web-client",
  "version": "0.1.0",
  "description": "EMCAP Angular CLI web client (SDD §9 metadata-driven UI)",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\"",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless --no-progress",
    "test:coverage": "ng test --configuration=coverage",
    "test:a11y": "ng test --watch=false --browsers=ChromeHeadless --no-progress --include=**/*.a11y.spec.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "19.2.25",
    "@angular/cdk": "19.2.19",
    "@angular/common": "19.2.25",
    "@angular/compiler": "19.2.25",
    "@angular/core": "19.2.25",
    "@angular/forms": "19.2.25",
    "@angular/material": "19.2.19",
    "@angular/platform-browser": "19.2.25",
    "@angular/platform-browser-dynamic": "19.2.25",
    "@angular/router": "19.2.25",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.27",
    "@angular-eslint/builder": "19.2.1",
    "@angular-eslint/eslint-plugin": "19.2.1",
    "@angular-eslint/eslint-plugin-template": "19.2.1",
    "@angular-eslint/schematics": "19.2.1",
    "@angular-eslint/template-parser": "19.2.1",
    "@angular/cli": "^19.2.27",
    "@angular/compiler-cli": "19.2.25",
    "@eslint/js": "^9.17.0",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "19.2.1",
    "axe-core": "^4.10.3",
    "eslint": "^9.17.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
